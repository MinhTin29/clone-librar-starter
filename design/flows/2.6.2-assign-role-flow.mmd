flowchart TD
    start([Start]) --> openUserList[Admin opens user list]
    openUserList --> checkRole{Logged in as admin?}
    checkRole -->|No| denyAccess[Redirect to login or show access denied]
    denyAccess --> endNode([End])
    checkRole -->|Yes| selectUser[Select a user]

    selectUser --> openRoleControl[Open role assignment control]
    openRoleControl --> chooseRole[Choose Reader, Librarian, or Admin]
    chooseRole --> confirmRole{Confirm role change?}
    confirmRole -->|No| endNode
    confirmRole -->|Yes| saveRole[Update user role]
    saveRole --> roleUpdated[Show role updated result]
    roleUpdated --> endNode
