flowchart TD
    start([Start]) --> openRegister[User clicks Dang ky]
    openRegister --> showForm[System displays registration form]

    subgraph reader[Reader]
        fillForm[Enter email, name, password, confirm password]
        submitForm[Click Tao tai khoan]
    end

    subgraph system[System]
        validateRequired{All fields filled?}
        validateEmail{Email format valid?}
        validateName{Name length <= 50?}
        validatePassword{Password length 8-16?}
        validateConfirm{Confirm matches password?}
        createAccount[Create account]
        setPending[Set status = Cho xac nhan]
        saveAccount[Save user record]
        success[Show success message]
    end

    subgraph errorHandling[Validation feedback]
        requiredError[Show required field errors]
        emailError[Show invalid email error]
        nameError[Show name length error]
        passwordError[Show password length error]
        confirmError[Show password mismatch error]
    end

    showForm --> fillForm
    fillForm --> submitForm
    submitForm --> validateRequired

    validateRequired -->|No| requiredError
    requiredError --> fillForm
    validateRequired -->|Yes| validateEmail

    validateEmail -->|No| emailError
    emailError --> fillForm
    validateEmail -->|Yes| validateName

    validateName -->|No| nameError
    nameError --> fillForm
    validateName -->|Yes| validatePassword

    validatePassword -->|No| passwordError
    passwordError --> fillForm
    validatePassword -->|Yes| validateConfirm

    validateConfirm -->|No| confirmError
    confirmError --> fillForm
    validateConfirm -->|Yes| createAccount

    createAccount --> setPending
    setPending --> saveAccount
    saveAccount --> success
    success --> endNode([End])
